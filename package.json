{
  "name": "@scwar/nestjs-prembly-sdk",
  "version": "1.1.0",
  "description": "A comprehensive NestJS module for integrating with the Prembly API",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint \"{src,scripts,test,examples}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.ts\"",
    "generate:catalog": "node scripts/generate-service-catalog.js",
    "generate:sdk": "node scripts/generate-sdk-files.js",
    "prepare": "husky",
    "version:patch": "npm version patch --no-git-tag-version && npm run changelog:update",
    "version:minor": "npm version minor --no-git-tag-version && npm run changelog:update",
    "version:major": "npm version major --no-git-tag-version && npm run changelog:update",
    "version:auto": "node scripts/version-bump.js",
    "changelog:update": "node scripts/update-changelog.js",
    "changelog:generate": "node scripts/update-changelog.js --full",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:auto": "node scripts/release.js auto",
    "prebuild": "npm run generate:sdk",
    "prepublishOnly": "npm run generate:sdk && npm run build && npm run test"
  },
  "keywords": [
    "nestjs",
    "prembly",
    "kyc",
    "kyb",
    "identity-verification",
    "fraud-detection",
    "typescript",
    "nodejs"
  ],
  "author": "Favour Max-Oti",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kellslte/nestjs-prembly-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/kellslte/nestjs-prembly-sdk/issues"
  },
  "homepage": "https://github.com/kellslte/nestjs-prembly-sdk#readme",
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
